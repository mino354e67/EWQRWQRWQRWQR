# Admin panel credentials (HTTP Basic Auth at /, /api/*)
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-please

# Bearer token for the /v1/* proxy endpoint.
# Clients put this in the `Authorization: Bearer <token>` header
# (or as the API key field in any OpenAI-compatible SDK).
# Generate a long random value, e.g. with: openssl rand -hex 32
PROXY_TOKEN=replace-with-long-random-string

# Optional
GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1
MONTHLY_COOLDOWN_USD=5
